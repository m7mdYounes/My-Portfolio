@model HomeViewModel

@{
    ViewData["Title"] = "Home";
    var profile = Model.Profile;
}

<section class="hero-section" id="home">
    <div class="hero-overlay"></div>

    <div class="container hero-container">
        <div class="hero-content text-center">
            <p class="hero-kicker">WELCOME TO MY PORTFOLIO</p>

            <h1 class="hero-title">
                I'm @(profile?.FullName ?? "Mohamed Younes")
            </h1>

            <h2 class="hero-subtitle">
                @(profile?.Title ?? ".NET Backend Engineer")
            </h2>

            <p class="hero-description">
                @(profile?.ShortSummary ?? "I build secure, scalable APIs and backend systems using ASP.NET Core, SQL Server, and clean architecture.")
            </p>

            <div class="hero-actions">
                <a href="#projects"
                   class="btn btn-primary-custom"
                   data-track-event="HeroProjectsClick"
                   data-track-component="Hero.ViewProjectsButton"
                   data-track-target-type="Section"
                   data-track-target-id="projects"
                   data-track-target-text="View Projects">
                    View Projects
                </a>

                @if (!string.IsNullOrWhiteSpace(profile?.CvFilePath))
                {
                    <a href="@profile.CvFilePath"
                       class="btn btn-outline-custom"
                       download
                       data-track-event="CvDownload"
                       data-track-component="Hero.CvButton"
                       data-track-target-type="File"
                       data-track-target-id="CV"
                       data-track-target-text="Download CV">
                        Download CV
                    </a>
                }
            </div>
        </div>
    </div>

    <a href="#about" class="scroll-down" aria-label="Scroll down">
        <i class="bi bi-chevron-down"></i>
    </a>
</section>

<section class="section-block about-section" id="about">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <div class="profile-card">
                    @if (!string.IsNullOrWhiteSpace(profile?.ProfileImagePath))
                    {
                        <img src="@profile.ProfileImagePath" alt="@profile.FullName" class="profile-image" />
                    }
                    else
                    {
                        <div class="profile-placeholder">
                            <span>MY</span>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-7">
                <p class="section-kicker">About Me</p>
                <h2 class="section-title">
                    Building backend systems that are clean, secure, and production-ready.
                </h2>

                <p class="section-text">
                    @(profile?.LongSummary ?? profile?.ShortSummary)
                </p>

                <div class="about-facts">
                    <div class="fact-item">
                        <span class="fact-number">@(profile?.YearsOfExperience ?? 3)+</span>
                        <span class="fact-label">Years Experience</span>
                    </div>

                    <div class="fact-item">
                        <span class="fact-number">.NET</span>
                        <span class="fact-label">Main Stack</span>
                    </div>

                    <div class="fact-item">
                        <span class="fact-number">SQL</span>
                        <span class="fact-label">Database Focus</span>
                    </div>
                </div>

                <a href="#contact"
                   class="btn btn-dark-custom mt-4"
                   data-track-event="AboutContactClick"
                   data-track-component="About.ContactButton"
                   data-track-target-type="Section"
                   data-track-target-id="contact"
                   data-track-target-text="Contact Me">
                    Contact Me
                </a>
            </div>
        </div>
    </div>
</section>

<section class="section-block dark-section" id="experience">
    <div class="container">
        <div class="section-heading text-center">
            <p class="section-kicker">Career</p>
            <h2 class="section-title text-white">Experience Timeline</h2>
            <p class="section-muted">
                A practical view of my backend engineering journey and responsibilities.
            </p>
        </div>

        <div class="timeline">
            @foreach (var item in Model.Experiences)
            {
                <div class="timeline-item">
                    <div class="timeline-dot"></div>

                    <div class="timeline-card">
                        <div class="timeline-header">
                            <div>
                                <h3>@item.JobTitle</h3>
                                <p>@item.CompanyName</p>
                            </div>

                            <span class="timeline-period">@item.Period</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(item.Location))
                        {
                            <div class="timeline-location">
                                <i class="bi bi-geo-alt"></i>
                                @item.Location
                            </div>
                        }

                        @if (item.Responsibilities.Any())
                        {
                            <ul class="timeline-list">
                                @foreach (var responsibility in item.Responsibilities)
                                {
                                    <li>@responsibility</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="section-block projects-section" id="projects">
    <div class="container">
        <div class="section-heading text-center">
            <p class="section-kicker">Portfolio</p>
            <h2 class="section-title">Featured Projects</h2>
            <p class="section-text mx-auto">
                Selected systems and platforms showing backend design, API development, SQL Server work, and production thinking.
            </p>
        </div>

        <div class="row g-4">
            @foreach (var project in Model.FeaturedProjects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="project-card">
                        <a asp-controller="Projects"
                           asp-action="Details"
                           asp-route-slug="@project.Slug"
                           class="project-image-link"
                           data-track-event="ProjectCardClick"
                           data-track-component="Home.FeaturedProjectCard"
                           data-track-target-type="Project"
                           data-track-target-id="@project.Id"
                           data-track-target-text="@project.Title">
                            @if (!string.IsNullOrWhiteSpace(project.MainImagePath))
                            {
                                <img src="@project.MainImagePath" alt="@project.Title" class="project-image" />
                            }
                            else
                            {
                                <div class="project-image-placeholder">
                                    <i class="bi bi-code-square"></i>
                                </div>
                            }
                        </a>

                        <div class="project-body">
                            <div class="project-meta">
                                <span>Featured</span>
                            </div>

                            <h3>@project.Title</h3>
                            <p>@project.ShortDescription</p>

                            <div class="tech-list">
                                @foreach (var skill in project.Skills.Take(4))
                                {
                                    <span>@skill</span>
                                }
                            </div>

                            <a asp-controller="Projects"
                               asp-action="Details"
                               asp-route-slug="@project.Slug"
                               class="project-link"
                               data-track-event="ProjectDetailsClick"
                               data-track-component="Home.ProjectDetailsLink"
                               data-track-target-type="Project"
                               data-track-target-id="@project.Id"
                               data-track-target-text="@project.Title">
                                View Details
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Projects"
               asp-action="Index"
               class="btn btn-dark-custom"
               data-track-event="AllProjectsClick"
               data-track-component="Home.AllProjectsButton"
               data-track-target-type="Page"
               data-track-target-id="projects"
               data-track-target-text="View All Projects">
                View All Projects
            </a>
        </div>
    </div>
</section>

<section class="section-block skills-section" id="skills">
    <div class="container">
        <div class="section-heading text-center">
            <p class="section-kicker">Tech Stack</p>
            <h2 class="section-title">Skills & Technologies</h2>
        </div>

        <div class="row g-4">
            @foreach (var category in Model.SkillCategories)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="skill-card">
                        <h3>@category.Name</h3>

                        <div class="skill-tags">
                            @foreach (var skill in category.Skills)
                            {
                                <span>@skill.Name</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="section-block contact-section" id="contact">
    <div class="container">
        <div class="contact-box text-center">
            <p class="section-kicker">Contact</p>
            <h2 class="section-title text-white">Let’s build something reliable.</h2>
            <p class="section-muted">
                Reach me through any of the links below.
            </p>

            <div class="contact-links">
                @foreach (var contact in Model.ContactLinks)
                {
                    <a href="@contact.Url"
                       target="_blank"
                       rel="noopener"
                       class="contact-link"
                       data-track-event="ContactClick"
                       data-track-component="Contact.@contact.Type"
                       data-track-target-type="ContactLink"
                       data-track-target-id="@contact.Id"
                       data-track-target-text="@contact.Label">
                        @if (!string.IsNullOrWhiteSpace(contact.Icon))
                        {
                            <i class="@contact.Icon"></i>
                        }
                        else
                        {
                            <i class="bi bi-link-45deg"></i>
                        }

                        <span>@contact.Label</span>
                    </a>
                }
            </div>
        </div>
    </div>
</section>