@model PagedResult<Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="admin-card">
    <div class="admin-card-header">
        <div>
            <h2>Projects</h2>
            <p>Manage portfolio projects and published status.</p>
        </div>

        <a asp-area="Admin" asp-controller="Projects" asp-action="Create" class="btn btn-primary rounded-pill px-4">
            Add Project
        </a>
    </div>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-5">
            <input name="searchTerm" class="form-control" placeholder="Search projects..." />
        </div>

        <div class="col-md-auto">
            <button type="submit" class="btn btn-dark rounded-pill px-4">
                Search
            </button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Slug</th>
                    <th>Featured</th>
                    <th>Published</th>
                    <th>Order</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(item.MainImagePath))
                                {
                                    <img src="@item.MainImagePath" class="preview-image" alt="@item.Title" />
                                }
                                <div>
                                    <strong>@item.Title</strong>
                                    <div class="text-muted small">@item.ShortDescription</div>
                                </div>
                            </div>
                        </td>

                        <td>@item.Slug</td>

                        <td>
                            @if (item.IsFeatured)
                            {
                                <span class="badge badge-soft-primary">Featured</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark">No</span>
                            }
                        </td>

                        <td>
                            @if (item.IsPublished)
                            {
                                <span class="badge badge-soft-success">Published</span>
                            }
                            else
                            {
                                <span class="badge badge-soft-danger">Hidden</span>
                            }
                        </td>

                        <td>@item.DisplayOrder</td>

                        <td class="text-end">
                            <div class="admin-actions justify-content-end">
                                <a asp-area="Admin" asp-controller="Projects" asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <form asp-area="Admin" asp-controller="Projects" asp-action="TogglePublish" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-dark" type="submit">Publish</button>
                                </form>

                                <form asp-area="Admin" asp-controller="Projects" asp-action="ToggleFeatured" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-secondary" type="submit">Feature</button>
                                </form>

                                <form asp-area="Admin" asp-controller="Projects" asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Delete this project?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>