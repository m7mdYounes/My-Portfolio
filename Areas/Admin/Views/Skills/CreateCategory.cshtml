@model SkillCategoryFormViewModel

@{
    ViewData["Title"] = "Create Skill Category";
}

<div class="admin-card">
    <div class="admin-card-header">
        <div>
            <h2>Create Skill Category</h2>
            <p>Add a new group like Backend, Database, Tools, or Security.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Skills" asp-action="CreateCategory" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-md-8">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-5">Save</button>
            <a asp-area="Admin" asp-controller="Skills" asp-action="Index" class="btn btn-outline-dark rounded-pill px-5">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}