@model SkillFormViewModel

@{
    ViewData["Title"] = "Create Skill";
}

<div class="admin-card">
    <div class="admin-card-header">
        <div>
            <h2>Create Skill</h2>
            <p>Add a technology under a skill category.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Skills" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="SkillCategoryId" class="form-label">Category</label>
                <select asp-for="SkillCategoryId" asp-items="Model.Categories" class="form-select"></select>
                <span asp-validation-for="SkillCategoryId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="IconPath" class="form-label"></label>
                <input asp-for="IconPath" class="form-control" placeholder="Optional icon class or path" />
            </div>

            <div class="col-md-3">
                <label asp-for="Level" class="form-label"></label>
                <input asp-for="Level" class="form-control" placeholder="Advanced" />
            </div>

            <div class="col-md-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
            </div>

            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsPublished" class="form-check-input" />
                    <label asp-for="IsPublished" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-5">Save</button>
            <a asp-area="Admin" asp-controller="Skills" asp-action="Index" class="btn btn-outline-dark rounded-pill px-5">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}