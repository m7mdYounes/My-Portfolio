@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="stat-grid">
    <div class="stat-card">
        <i class="bi bi-kanban"></i>
        <span>Total Projects</span>
        <strong>@Model.TotalProjects</strong>
    </div>

    <div class="stat-card">
        <i class="bi bi-eye"></i>
        <span>Published Projects</span>
        <strong>@Model.PublishedProjects</strong>
    </div>

    <div class="stat-card">
        <i class="bi bi-star"></i>
        <span>Featured Projects</span>
        <strong>@Model.FeaturedProjects</strong>
    </div>

    <div class="stat-card">
        <i class="bi bi-briefcase"></i>
        <span>Experiences</span>
        <strong>@Model.TotalExperiences</strong>
    </div>

    <div class="stat-card">
        <i class="bi bi-tools"></i>
        <span>Skills</span>
        <strong>@Model.TotalSkills</strong>
    </div>

    <div class="stat-card">
        <i class="bi bi-link-45deg"></i>
        <span>Contact Links</span>
        <strong>@Model.TotalContactLinks</strong>
    </div>
</div>

<div class="admin-card mt-4">
    <div class="admin-card-header">
        <div>
            <h2>Quick Actions</h2>
            <p>Common portfolio management tasks.</p>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-area="Admin" asp-controller="Profile" asp-action="Edit" class="btn btn-primary rounded-pill px-4">
            Edit Profile
        </a>

        <a asp-area="Admin" asp-controller="Projects" asp-action="Create" class="btn btn-dark rounded-pill px-4">
            Add Project
        </a>

        <a asp-area="Admin" asp-controller="Experiences" asp-action="Create" class="btn btn-outline-dark rounded-pill px-4">
            Add Experience
        </a>

        <a asp-area="Admin" asp-controller="Skills" asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">
            Add Skill
        </a>
    </div>
</div>